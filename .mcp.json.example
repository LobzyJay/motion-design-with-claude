{
  "mcpServers": {
    "AfterEffectsMCP": {
      "command": "node",
      "args": ["/absolute/path/to/after-effects-mcp/build/index.js"],
      "description": "After Effects MCP by TheLlamainator. Requires mcp-bridge-auto.jsx open in AE with Auto-run commands ticked."
    },
    "BlenderMCP": {
      "type": "sse",
      "url": "http://localhost:9876/sse",
      "description": "Official Blender Lab MCP. Requires the add-on enabled in Blender and Start MCP Server clicked."
    }
  }
}
